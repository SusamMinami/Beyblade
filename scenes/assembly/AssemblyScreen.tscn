[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/assembly/assembly_screen.gd" id="1"]

[node name="AssemblyScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 48.0
offset_top = 48.0
offset_right = -48.0
offset_bottom = -48.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="TitleLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "陀螺设计"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 34

[node name="HintLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "选择外圈、配重和底尖。MVP 阶段先验证选择流程，后续接入真实物理参数。"
autowrap_mode = 3

[node name="RingLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "外圈"

[node name="RingOptions" type="OptionButton" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2

[node name="WeightLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "配重"

[node name="WeightOptions" type="OptionButton" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2

[node name="TipLabel" type="Label" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "底尖"

[node name="TipOptions" type="OptionButton" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2

[node name="SummaryLabel" type="Label" parent="MarginContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "当前组装"
autowrap_mode = 3

[node name="Spacer" type="Control" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3

[node name="NextButton" type="Button" parent="MarginContainer/VBoxContainer"]
layout_mode = 2
text = "下一步：选择地图"

[connection signal="item_selected" from="MarginContainer/VBoxContainer/RingOptions" to="." method="_on_option_changed"]
[connection signal="item_selected" from="MarginContainer/VBoxContainer/WeightOptions" to="." method="_on_option_changed"]
[connection signal="item_selected" from="MarginContainer/VBoxContainer/TipOptions" to="." method="_on_option_changed"]
[connection signal="pressed" from="MarginContainer/VBoxContainer/NextButton" to="." method="_on_next_button_pressed"]
